<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:orientation="vertical" android:gravity="center"
    android:background="@color/bg_dark">

    <ImageView android:id="@+id/iv_logo"
        android:layout_width="100dp" android:layout_height="100dp"
        android:src="@drawable/ic_logo"
        android:background="@drawable/bg_splash_logo"
        android:padding="20dp"
        android:layout_marginBottom="28dp"/>

    <TextView android:id="@+id/tv_app_name"
        android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="TikAI Tool"
        android:textSize="36sp" android:textStyle="bold"
        android:textColor="@color/accent_pink"
        android:layout_marginBottom="10dp"/>

    <TextView android:id="@+id/tv_tagline"
        android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="AI-powered TikTok companion"
        android:textSize="15sp" android:textColor="@color/text_secondary"
        android:layout_marginBottom="60dp"/>

    <ProgressBar android:id="@+id/progress_bar"
        style="?android:attr/progressBarStyleSmall"
        android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:indeterminateTint="@color/accent_purple"/>
</LinearLayout>
