<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:background="@color/bg_dark" android:fillViewport="true">
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="vertical" android:padding="16dp">

        <!-- Header card -->
        <LinearLayout android:id="@+id/card_header"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical" android:paddingBottom="20dp">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="TikAI Tool" android:textSize="32sp" android:textStyle="bold"
                android:textColor="@color/accent_pink"/>
            <TextView android:id="@+id/tv_status"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="● AI Overlay Off" android:textSize="12sp"
                android:textColor="@color/text_secondary" android:layout_marginTop="4dp"/>
        </LinearLayout>

        <!-- API warning -->
        <TextView android:id="@+id/tv_api_warn"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="⚠  No API key — tap here to set it in Settings"
            android:textColor="@color/warning_yellow" android:textSize="12sp"
            android:background="#1AEAB308" android:padding="14dp"
            android:layout_marginBottom="14dp" android:visibility="gone"/>

        <!-- Action cards -->
        <LinearLayout android:id="@+id/card_actions"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical" android:background="@drawable/bg_card"
            android:padding="16dp" android:layout_marginBottom="12dp">

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="ACTIONS" android:textSize="10sp" android:letterSpacing="0.18"
                android:textColor="@color/text_secondary" android:layout_marginBottom="14dp"/>

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:layout_marginBottom="10dp">
                <Button android:id="@+id/btn_open_tiktok"
                    android:layout_width="0dp" android:layout_height="54dp" android:layout_weight="1"
                    android:text="Open TikTok" android:textColor="@color/white"
                    android:background="@drawable/bg_btn_secondary"
                    android:textSize="14sp" android:layout_marginEnd="8dp"/>
                <Button android:id="@+id/btn_ai_finder"
                    android:layout_width="0dp" android:layout_height="54dp" android:layout_weight="1"
                    android:text="✨ AI Finder" android:textColor="@color/white"
                    android:background="@drawable/bg_btn_primary"
                    android:textStyle="bold" android:textSize="14sp"/>
            </LinearLayout>

            <Button android:id="@+id/btn_stop_overlay"
                android:layout_width="match_parent" android:layout_height="44dp"
                android:text="Stop Overlay" android:textColor="@color/red"
                android:background="@drawable/bg_btn_danger"
                android:textSize="13sp" android:visibility="gone"/>
        </LinearLayout>

        <!-- Download card -->
        <LinearLayout android:id="@+id/card_download"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical" android:background="@drawable/bg_card"
            android:padding="16dp" android:layout_marginBottom="12dp">

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="DOWNLOAD (NO WATERMARK)" android:textSize="10sp"
                android:letterSpacing="0.18" android:textColor="@color/text_secondary"
                android:layout_marginBottom="12dp"/>

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal">
                <EditText android:id="@+id/et_url"
                    android:layout_width="0dp" android:layout_height="50dp" android:layout_weight="1"
                    android:hint="Paste TikTok URL..." android:textColor="@color/text_primary"
                    android:textColorHint="@color/text_hint" android:background="@drawable/bg_input"
                    android:paddingStart="14dp" android:paddingEnd="14dp"
                    android:inputType="textUri" android:singleLine="true"
                    android:layout_marginEnd="8dp"/>
                <Button android:id="@+id/btn_paste"
                    android:layout_width="50dp" android:layout_height="50dp"
                    android:text="📋" android:background="@drawable/bg_btn_secondary"
                    android:padding="0dp" android:layout_marginEnd="8dp"/>
                <Button android:id="@+id/btn_download"
                    android:layout_width="70dp" android:layout_height="50dp"
                    android:text="Get" android:textColor="@color/white"
                    android:background="@drawable/bg_btn_primary" android:textStyle="bold"/>
            </LinearLayout>
        </LinearLayout>

        <!-- Bottom row -->
        <LinearLayout android:id="@+id/card_bottom"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal">
            <Button android:id="@+id/btn_history"
                android:layout_width="0dp" android:layout_height="48dp" android:layout_weight="1"
                android:text="📋 History" android:textColor="@color/text_primary"
                android:background="@drawable/bg_btn_secondary" android:layout_marginEnd="8dp"
                android:textSize="13sp"/>
            <Button android:id="@+id/btn_settings"
                android:layout_width="0dp" android:layout_height="48dp" android:layout_weight="1"
                android:text="⚙ Settings" android:textColor="@color/text_primary"
                android:background="@drawable/bg_btn_secondary" android:textSize="13sp"/>
        </LinearLayout>

    </LinearLayout>
</ScrollView>
